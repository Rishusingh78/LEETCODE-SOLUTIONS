class Solution {
public:
    int minOperations(string s) {
        int n = s.length();
        int pattern1 = 0, pattern2 = 0;

        for(int i = 0; i < n; i++) {
            if(s[i] != (i % 2 == 0 ? '0' : '1'))
                pattern1++;

            if(s[i] != (i % 2 == 0 ? '1' : '0'))
                pattern2++;
        }

        return min(pattern1, pattern2);
    }
};
