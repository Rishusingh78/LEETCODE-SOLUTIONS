class Solution {
public:
    int minOperations(vector<vector<int>>& grid, int x) {
        vector<int> v;

        
        for (auto &row : grid) {
            for (int val : row) {
                v.push_back(val);
            }
        }

        
        int base = v[0];
        for (int val : v) {
            if ((val - base) % x != 0) return -1;
        }

       
        sort(v.begin(), v.end());

        
        int median = v[v.size() / 2];

        
        int ops = 0;
        for (int val : v) {
            ops += abs(val - median) / x;
        }

        return ops;
    }
};
